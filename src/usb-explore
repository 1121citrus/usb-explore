#!/usr/bin/env bash
# usb-explore — inspect Linux USB disk images from macOS via Docker.
#
# Copyright (C) 2026 1121 Citrus
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# SYNOPSIS
#   usb-explore <subcommand> [options] [arguments]
#
# SUBCOMMANDS
#   archive [-i|--image PATH] [-p|--partition N] <src-path> <dest>
#             Create a compressed archive of <src-path> (absolute within
#             the partition) at <dest> on the host. Compression format is
#             inferred from the file extension:
#             .tar.gz / .tgz  .tar.bz2 / .tbz2  .tar.xz / .txz  .tar
#
#   browse  [-i|--image PATH] [-p|--partition N]
#             Launch Midnight Commander (mc) at the partition root for
#             visual twin-panel navigation. Requires a terminal (TTY).
#             Press F10 or q to quit. ncdu is also available inside
#             the container for disk-usage analysis.
#
#   build   [--no-cache]
#             Build or rebuild the Docker image from local source.
#
#   capture <device> [-o|--output PATH] [--no-sparse]
#             [--progress-interval N] [--dry-run]
#             Copy a USB device to a disk image file using dd.
#             This is the only subcommand that does NOT use Docker.
#
#   clean   [-i|--image PATH] [-y|--yes]
#             Remove the captured disk image file. Prompts for
#             confirmation unless -y/--yes is given. Does not require
#             Docker.
#
#   copy    [-i|--image PATH] [-p|--partition N] <src-path> <dest>
#             Copy <src-path> (absolute within the partition) to <dest>
#             on the host. Directories are copied recursively.
#
#   diff    [-i|--image PATH] [-p|--partition N] <image-path> <ref-path>
#             Diff <image-path> (within the partition) against <ref-path>
#             on the host. Exit code: 0=identical, 1=different, 2=error.
#
#   edit    [-i|--image PATH] [-p|--partition N] [--yes] [--] [cmd...]
#             Mount read-write and run an interactive shell or command.
#             Creates an APFS reflink backup (.pre-edit) before the
#             first write session. Prompts for confirmation unless
#             --yes is given. Not supported on squashfs, erofs, or
#             iso9660 (inherently read-only).
#
#   find    [-i|--image PATH] [-p|--partition N]
#             [--grep PATTERN] [NAME-GLOB]
#             Search the partition. NAME-GLOB finds files by name
#             (e.g. "*.log"). --grep PATTERN searches file contents.
#             Both flags may be combined. Output paths are relative to
#             the partition root and usable directly with copy/archive.
#             Exit 1 when --grep finds no matches (standard grep
#             behaviour); exit 0 when a name search finds nothing.
#
#   hash    [-i|--image PATH] [-p|--partition N] <path>
#             Print the SHA-256 checksum of <path> (absolute within the
#             partition) without extracting the file to the host. Output
#             format is identical to sha256sum(1): "<digest>  <path>".
#
#   info    [-i|--image PATH] [--json]
#             Print the partition table and filesystem metadata.
#             --json emits machine-readable JSON.
#
#   mount   [-i|--image PATH] [-p|--partition N] [--port PORT]
#             [--no-open]
#             Mount the partition as a Finder-browseable SMB volume.
#             The volume appears under /Volumes/ and in the Finder
#             sidebar. Press Ctrl-C to unmount and stop. No sudo
#             required.
#
#   unmount   Unmount all usb-explore SMB volumes. Also triggered by
#             ejecting from Finder or pressing Ctrl-C during mount.
#
#   run     [-i|--image PATH] [-p|--partition N] [--rw]
#             [--] <cmd> [args...]
#             Run a command inside the container with the partition
#             mounted. Arguments starting with / are automatically
#             prefixed with /mnt/part.
#             --rw mounts read-write (no backup, no confirmation).
#
#   serve   [-i|--image PATH] [-p|--partition N] [--port PORT]
#             [--no-open]
#             Start a read-only HTTP file server on the host at
#             http://localhost:PORT (default 8080), browseable in any
#             web browser. Press Ctrl-C to stop.
#             --no-open suppresses the automatic browser launch.
#             The browser is also suppressed automatically in SSH
#             sessions and headless environments.
#
#   shell   [-i|--image PATH] [-p|--partition N] [--rw]
#             Start an interactive bash shell with a partition mounted
#             at /mnt/part inside the container.
#             --rw mounts read-write (no backup, no confirmation).
#
# GLOBAL OPTIONS
#   -i|--image PATH        Disk image file (default: ./usb.img)
#   -p|--partition N       Partition number to mount (default: auto)
#   --lv NAME              Select a specific LVM logical volume by name
#   --luks-passphrase PP   Passphrase for LUKS-encrypted partitions
#                          (visible in docker inspect; prefer
#                          --luks-passphrase-file for sensitive use)
#   --luks-passphrase-file PATH
#                          Read LUKS passphrase from a file (not
#                          exposed in process args or env vars)
#   --luks-key-file PATH   Binary key file for LUKS-encrypted partitions
#   --debug                Print docker run commands before executing
#   --version              Print version and exit
#   --help                 Print this help and exit
#
# ENVIRONMENT
#   USB_EXPLORE_REGISTRY   Docker Hub registry prefix (default: 1121citrus)
#   USB_EXPLORE_TAG        Image tag to use (default: latest)
#   USB_EXPLORE_IMAGE      Default disk image path (default: ./usb.img)
#
# NOTES
#   • capture requires macOS 13+ for dd conv=sparse (APFS sparse files).
#   • All other subcommands require Docker Desktop to be running.
#   • The container runs --privileged as root. See SECURITY.md.
#
# EXAMPLES
#   # Step 1: copy the USB drive to a disk image (run once)
#   usb-explore capture /dev/disk4
#
#   # Step 2: see what partitions are on the image
#   usb-explore info
#
#   # Step 3a: browse the filesystem interactively
#   usb-explore shell
#
#   # Step 3b: copy a specific file to the current directory
#   usb-explore copy /etc/fstab ./fstab
#
#   # Step 3c: run a command against the image
#   usb-explore run -- find /home -name '*.log'
#
#   # Step 3d: diff the image /etc against a local reference
#   usb-explore diff /etc ./reference-etc

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve paths and image reference
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

REGISTRY="${USB_EXPLORE_REGISTRY:-1121citrus}"
IMAGE_TAG="${USB_EXPLORE_TAG:-latest}"
IMAGE_REF="${REGISTRY}/usb-explore:${IMAGE_TAG}"

IMAGE_FILE="${USB_EXPLORE_IMAGE:-./usb.img}"
PARTITION=""
LV_NAME=""
LUKS_PASSPHRASE=""
LUKS_PASSPHRASE_FILE=""
LUKS_KEY_FILE=""
RW_MODE=false
DEBUG=false
CONTAINER_NAME="usb-explore-$$"
CONTAINER_STARTED=false

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------

log()  { echo "usb-explore: ${*}" >&2; }
err()  { echo "usb-explore: error: ${*}" >&2; }
die()  { err "${*}"; exit 1; }
warn() { echo "usb-explore: warning: ${*}" >&2; }

# ---------------------------------------------------------------------------
# Preflight checks
# ---------------------------------------------------------------------------

# check_docker — exit 3 if Docker is not running or not responding.
# Args: none
# Returns: 0 if Docker is available
check_docker() {
    if ! docker info >/dev/null 2>&1; then
        err "Docker is not running or is not responding."
        err "Start Docker Desktop and try again."
        exit 3
    fi
}

# check_image_file — exit 4 if the disk image does not exist.
# Args: none (reads IMAGE_FILE)
# Returns: 0 if file exists
check_image_file() {
    if [[ ! -f "${IMAGE_FILE}" ]]; then
        err "Image file not found: ${IMAGE_FILE}"
        err "Run 'usb-explore capture <device>' to create one,"
        err "or pass -i <path> to specify a different image."
        exit 4
    fi
}

# ensure_image — pull or build the container image if not present locally.
# Args: none
# Returns: 0 when image is available in the local daemon
ensure_image() {
    if docker image inspect "${IMAGE_REF}" >/dev/null 2>&1; then
        return 0
    fi
    log "Image ${IMAGE_REF} not found locally. Attempting pull..."
    if docker pull "${IMAGE_REF}" 2>/dev/null; then
        return 0
    fi
    if [[ -f "${REPO_ROOT}/Dockerfile" ]]; then
        log "Pull failed. Building from local source..."
        bash "${REPO_ROOT}/build" --no-lint --no-test --no-scan
    else
        die "Image not available and no local Dockerfile found." \
            "Run: docker pull ${IMAGE_REF}"
    fi
}

# ---------------------------------------------------------------------------
# Interrupt / cleanup
# ---------------------------------------------------------------------------

_cleanup() {
    "${CONTAINER_STARTED}" && \
        docker stop "${CONTAINER_NAME}" >/dev/null 2>&1 || true
}
trap '_cleanup' INT TERM EXIT

# ---------------------------------------------------------------------------
# Partition auto-selection
# ---------------------------------------------------------------------------

# resolve_partition — auto-select the mountable partition.
# Delegates to the container's select-partition command so all jq processing
# stays inside the container (jq is guaranteed present; host may not have it).
# Args: none (reads IMAGE_FILE, IMAGE_REF; sets PARTITION)
# Returns: 0 with PARTITION set; exits with container exit code on error
resolve_partition() {
    [[ -n "${PARTITION}" ]] && return 0

    local result
    result=$(docker run --rm --privileged \
        -v "$(realpath "${IMAGE_FILE}"):/disk.img:ro" \
        "${IMAGE_REF}" select-partition) || exit $?

    local num rest fs size
    num="${result%% *}"
    rest="${result#* }"
    fs="${rest%% *}"
    size="${rest#* }"

    PARTITION="${num}"
    log "Selected partition ${PARTITION} (${fs}, ${size})"
}

# ---------------------------------------------------------------------------
# Container runner
# ---------------------------------------------------------------------------

# run_container — execute a docker run with all standard flags.
# Args: extra docker flags (before image ref), then image + cmd
# Reads globals: IMAGE_FILE, IMAGE_REF, CONTAINER_NAME, DEBUG,
#   LV_NAME, LUKS_PASSPHRASE, LUKS_KEY_FILE
run_container() {
    local disk_mount_mode="ro"
    [[ "${RW_MODE}" == true ]] && disk_mount_mode="rw"

    local docker_args=(
        run
        --rm
        --privileged
        --name "${CONTAINER_NAME}"
        -v "$(realpath "${IMAGE_FILE}"):/disk.img:${disk_mount_mode}"
        -e "USB_PARTITION=${PARTITION:-}"
        -e "USB_EXPLORE_RUN_SCOPE=${CONTAINER_NAME}"
    )

    # Read-write mode
    [[ "${RW_MODE}" == true ]] && \
        docker_args+=(-e "USB_EXPLORE_RW=true")

    # Storage layer credentials and selection
    [[ -n "${LV_NAME}" ]] && \
        docker_args+=(-e "USB_EXPLORE_LV=${LV_NAME}")
    [[ -n "${LUKS_PASSPHRASE}" ]] && \
        docker_args+=(-e "USB_EXPLORE_LUKS_PASSPHRASE=${LUKS_PASSPHRASE}")
    if [[ -n "${LUKS_PASSPHRASE_FILE}" ]]; then
        docker_args+=(-v "$(realpath "${LUKS_PASSPHRASE_FILE}"):/run/luks-passphrase:ro")
        docker_args+=(-e "USB_EXPLORE_LUKS_PASSPHRASE_FILE=/run/luks-passphrase")
    fi
    if [[ -n "${LUKS_KEY_FILE}" ]]; then
        docker_args+=(-v "$(realpath "${LUKS_KEY_FILE}"):/run/luks-key:ro")
        docker_args+=(-e "USB_EXPLORE_LUKS_KEY_FILE=/run/luks-key")
    fi

    # Append any extra flags passed by the caller (e.g. -v, -e, -it)
    docker_args+=("$@")

    if [[ "${DEBUG}" == true ]]; then
        echo "[debug] docker ${docker_args[*]}" >&2
    fi

    # Suppress Docker Desktop's "What's next:" hint block, which otherwise
    # appears after interactive sessions and shifts terminal content down,
    # breaking the cursor cleanup in do_shell.
    CONTAINER_STARTED=true
    DOCKER_CLI_HINTS=false docker "${docker_args[@]}"
}

# set_tty_flags — populate TTY_FLAGS array with -i -t when interactive,
# or nothing when stdout is piped/redirected.
#
# With just -i and no -t, Docker attaches stdin but the container's stdout
# can block waiting for stdin EOF before flushing — piped output never
# arrives at the reader. Using -i -t only when both fds are terminals, and
# no flags otherwise, lets Docker forward stdout directly to the pipe.
# Args: none; sets global TTY_FLAGS
set_tty_flags() {
    if [[ -t 0 && -t 1 ]]; then
        TTY_FLAGS=(-i -t)
    else
        TTY_FLAGS=()
    fi
}

TTY_FLAGS=()   # default; updated by set_tty_flags before each container call

# _progress_monitor — print a progress line to stderr every INTERVAL seconds.
# Reads the output file size with /usr/bin/stat (BSD stat, explicit path to
# avoid GNU stat from pkgin/Homebrew which interprets -f differently).
# Args:
#   $1 = interval (seconds between lines)
#   $2 = total bytes (from diskutil; 0 disables percentage and ETA)
#   $3 = output file path being monitored
#   $4 = start timestamp (seconds since epoch, from date +%s)
# Returns: runs until killed; never exits normally
_progress_monitor() {
    local interval="${1}" total="${2}" out="${3}" start="${4}"
    while sleep "${interval}"; do
        local written elapsed speed pct eta_s
        written=$(/usr/bin/stat -f %z "${out}" 2>/dev/null || echo 0)
        elapsed=$(( $(date +%s) - start ))
        speed=0
        [[ "${elapsed}" -gt 0 ]] && speed=$(( written / elapsed ))
        pct=0
        [[ "${total}" -gt 0 ]] && pct=$(( written * 100 / total ))
        eta_s=0
        [[ "${speed}" -gt 0 && "${total}" -gt "${written}" ]] && \
            eta_s=$(( (total - written) / speed ))
        printf "  %s / %s (%d%%)  %s/s  elapsed %dm%02ds  ETA %dm%02ds\n" \
            "$(_fmt_bytes "${written}")" \
            "$(_fmt_bytes "${total}")" \
            "${pct}" \
            "$(_fmt_bytes "${speed}")" \
            "$(( elapsed / 60 ))" "$(( elapsed % 60 ))" \
            "$(( eta_s  / 60 ))" "$(( eta_s  % 60 ))" >&2
    done
}

# _fmt_bytes — format a byte count as a human-readable string.
# Args: $1 = bytes (integer or "?")
# Returns: 0; writes formatted string to stdout
_fmt_bytes() {
    local bytes="${1}"
    [[ "${bytes}" == "?" ]] && echo "?" && return
    awk -v b="${bytes}" 'BEGIN {
        split("B KB MB GB TB", s)
        i = 1
        while (b >= 1024 && i < 5) { b /= 1024; i++ }
        printf "%.1f %s\n", b, s[i]
    }'
}

# ---------------------------------------------------------------------------
# Subcommand: archive
# ---------------------------------------------------------------------------

# Create a compressed archive of a partition path on the host.
# Args:
#   [-p|--partition N]  override auto-detected partition number
#   <src-path>          absolute path within the partition
#   <dest>              host output path; extension determines compression
# Returns:
#   0 on success; non-zero on bad arguments, Docker error, or missing path
do_archive() {
    local src="" dest=""
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            -*) die "Unknown archive option: ${1}" ;;
            *)
                if [[ -z "${src}" ]]; then
                    src="${1}"
                elif [[ -z "${dest}" ]]; then
                    dest="${1}"
                else
                    die "Unexpected argument: ${1}"
                fi ;;
        esac
        shift
    done

    [[ -n "${src}" ]]  || die "archive requires <src-path>"
    [[ -n "${dest}" ]] || die "archive requires <dest>"
    [[ "${src}" == /* ]] || die "<src-path> must be absolute (start with /)"
    src="${src#/mnt/part}"

    local out_name
    out_name="$(basename "${dest}")"

    # Validate extension locally for immediate feedback before Docker spin-up
    case "${out_name}" in
        *.tar.gz|*.tgz|*.tar.bz2|*.tbz2|*.tar.xz|*.txz|*.tar) ;;
        *) die "unsupported archive format: ${out_name}
       Supported extensions: .tar.gz .tgz .tar.bz2 .tbz2 .tar.xz .txz .tar" ;;
    esac

    check_docker
    check_image_file
    ensure_image
    resolve_partition
    set_tty_flags

    # Resolve host-side output directory; create if needed
    local out_dir
    local dest_parent
    dest_parent="$(dirname "${dest}")"
    mkdir -p "${dest_parent}"
    out_dir="$(cd "${dest_parent}" && pwd)"

    run_container \
        -v "${out_dir}:/out" \
        "${TTY_FLAGS[@]}" \
        "${IMAGE_REF}" archive "${src}" "${out_name}"
}

# ---------------------------------------------------------------------------
# Subcommand: browse
# ---------------------------------------------------------------------------

# Launch Midnight Commander at the partition root for visual navigation.
# Args:
#   [-p|--partition N]  override auto-detected partition number
# Returns:
#   Exit code from mc; container must be attached to a TTY.
do_browse() {
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            -*) die "Unknown browse option: ${1}" ;;
            *) die "Unexpected argument: ${1}" ;;
        esac
        shift
    done

    check_docker
    check_image_file
    ensure_image
    resolve_partition

    local rc=0
    run_container \
        -i -t \
        "${IMAGE_REF}" browse || rc=$?
    # 130 = SIGINT (Ctrl-C); expected exit for interactive subcommands.
    # set -e prevents a plain rc=$? assignment after a non-zero command,
    # so the || idiom is required to capture the code without triggering errexit.
    [[ "${rc}" -eq 130 ]] && return 0
    return "${rc}"
}

# ---------------------------------------------------------------------------
# Subcommand: build
# ---------------------------------------------------------------------------

do_build() {
    local no_cache=false
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            --no-cache) no_cache=true ;;
            *) die "Unknown build option: ${1}" ;;
        esac
        shift
    done

    if [[ ! -f "${REPO_ROOT}/build" ]]; then
        die "build script not found at ${REPO_ROOT}/build." \
            "Clone the repository to build from source."
    fi

    local args=(--no-lint --no-test --no-scan)
    [[ "${no_cache}" == true ]] && args+=(--no-cache)
    exec bash "${REPO_ROOT}/build" "${args[@]}"
}

# ---------------------------------------------------------------------------
# Subcommand: capture
# ---------------------------------------------------------------------------

do_capture() {
    local device="" output="${IMAGE_FILE}" no_sparse=false
    local progress_interval=5 dry_run=false

    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -o|--output) output="${2}"; shift ;;
            --no-sparse) no_sparse=true ;;
            --progress-interval) progress_interval="${2}"; shift ;;
            --dry-run) dry_run=true ;;
            -*) die "Unknown capture option: ${1}" ;;
            *)  [[ -z "${device}" ]] || die "Unexpected argument: ${1}"
                device="${1}" ;;
        esac
        shift
    done

    [[ -n "${device}" ]] || die "capture requires a device argument (e.g. /dev/disk4)"

    # Validate: whole-disk node only (no partition slice)
    if [[ ! "${device}" =~ ^/dev/disk[0-9]+$ ]]; then
        die "Expected a whole-disk device (e.g. /dev/disk4), got: ${device}"
    fi

    # Confirm the device exists
    if ! diskutil info "${device}" >/dev/null 2>&1; then
        die "Device not found: ${device}"
    fi

    # Unmount any mounted partitions
    if diskutil unmountDisk "${device}" >/dev/null 2>&1; then
        log "Unmounted ${device}"
    fi

    # Use the raw device for higher throughput
    local raw_device="${device/\/dev\/disk//dev/rdisk}"

    # Check output filesystem for APFS (sparse file support)
    local out_dir; out_dir="$(dirname "$(realpath "${output}" 2>/dev/null \
                              || echo "${output}")")"
    if [[ -d "${out_dir}" ]]; then
        local out_mount fs_type
        out_mount=$(df -P "${out_dir}" 2>/dev/null | awk 'NR==2 {print $6}')
        fs_type=$(diskutil info "${out_mount}" 2>/dev/null \
                  | awk -F': *' '/File System Personality/ {print $2}' \
                  || echo "")
        if [[ "${fs_type}" != *APFS* && "${no_sparse}" == false ]]; then
            warn "Output volume is ${fs_type:-unknown}, not APFS."
            warn "Sparse copy will not save disk space on this volume."
        fi
    fi

    # Use /bin/dd explicitly: this tool is macOS-only and requires BSD dd
    # for conv=sparse and SIGINFO progress. Augmented PATH toolsets (pkgin,
    # Homebrew) may put GNU dd first; that breaks both features.
    local dd_args=("if=${raw_device}" "of=${output}" "bs=4m")
    [[ "${no_sparse}" == false ]] && dd_args+=("conv=sparse")

    log "Capturing ${raw_device} → $(realpath "${output}" 2>/dev/null || echo "${output}")"
    log "Sparse: $([[ "${no_sparse}" == false ]] && echo enabled || echo disabled)"

    if [[ "${dry_run}" == true ]]; then
        echo "[dry-run] sudo /bin/dd ${dd_args[*]}"
        return 0
    fi

    local start_ts; start_ts=$(date +%s)

    # Build a PID file so the background monitor can signal the dd process.
    # Strategy: run "sudo bash -c 'echo $$ > pidfile; exec dd ...'". After
    # exec, the bash process IS dd (same PID), so the file holds dd's PID.
    # dd runs in the foreground → terminal Ctrl-T (SIGINFO) reaches it directly.
    local pid_file dd_args_q pid_file_q
    pid_file=$(mktemp)
    printf -v dd_args_q ' %q' "${dd_args[@]}"
    printf -v pid_file_q '%q' "${pid_file}"

    # Background monitor: two lines per interval.
    #   1. "X written  Ym Zs elapsed" — sparse output file size (always reliable)
    #   2. dd's own SIGINFO line — "N bytes transferred (rate)" — actual READ rate
    #
    # "sudo -n" is non-interactive: refreshes the cached credential on each
    # successful call without prompting; fails silently when expired so the
    # heartbeat line continues even if SIGINFO stops.
    #
    # NOTE: conv=sparse means the output file only grows when non-zero blocks
    # are written. The dd SIGINFO line is the accurate source of truth for how
    # much of the input device has actually been read.
    {
        local dd_pid="" deadline=$(( $(date +%s) + 5 ))
        while [[ -z "${dd_pid}" && $(date +%s) -lt "${deadline}" ]]; do
            sleep 0.2
            [[ -f "${pid_file}" ]] && \
                dd_pid=$(cat "${pid_file}" 2>/dev/null) || true
        done
        while sleep "${progress_interval}"; do
            local elapsed written
            elapsed=$(( $(date +%s) - start_ts ))
            written=$(/usr/bin/stat -f %z "${output}" 2>/dev/null || echo 0)
            printf "  %s written to disk  %dm%02ds elapsed\n" \
                "$(_fmt_bytes "${written}")" \
                "$(( elapsed / 60 ))" "$(( elapsed % 60 ))" >&2
            # SIGINFO → dd prints "N bytes transferred (rate)" on the next line.
            # This shows the actual input-device read rate, which is unaffected
            # by sparse skipping.
            [[ -n "${dd_pid}" ]] && \
                sudo -n /bin/kill -INFO "${dd_pid}" 2>/dev/null || true
        done
    } &
    local monitor_pid=$!
    trap 'kill "${monitor_pid}" 2>/dev/null
          wait "${monitor_pid}" 2>/dev/null || true
          rm -f "${pid_file}"' RETURN

    sudo /bin/bash -c "
        printf '%d' \$\$ > ${pid_file_q}
        exec /bin/dd${dd_args_q}
    "
    local dd_rc=$?

    kill "${monitor_pid}" 2>/dev/null
    wait "${monitor_pid}" 2>/dev/null || true
    trap - RETURN
    rm -f "${pid_file}"

    [[ "${dd_rc}" -ne 0 ]] && die "dd failed with exit code ${dd_rc}"

    # Post-capture validation
    if [[ ! -s "${output}" ]]; then
        die "Output file is missing or empty: ${output}"
    fi

    local logical physical
    logical=$(/usr/bin/stat -f %z "${output}" 2>/dev/null || echo "?")
    physical=$(du -sh "${output}" 2>/dev/null | cut -f1 || echo "?")
    log "Capture complete."
    log "  Logical size:  $(_fmt_bytes "${logical}")"
    log "  Physical size: ${physical}"
}

# ---------------------------------------------------------------------------
# Subcommand: clean
# ---------------------------------------------------------------------------

# Remove the captured disk image file after confirming with the user.
# Args:
#   [-y|--yes]  skip confirmation prompt (for scripting)
# Returns:
#   0 on success or aborted; 4 if the file does not exist
do_clean() {
    local yes=false
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -i|--image)
                [[ -n "${2:-}" ]] || die "--image requires a path"
                IMAGE_FILE="${2}"; shift ;;
            -y|--yes) yes=true ;;
            -*) die "Unknown clean option: ${1}" ;;
            *) die "Unexpected argument: ${1}" ;;
        esac
        shift
    done

    if [[ ! -f "${IMAGE_FILE}" ]]; then
        err "Image file not found: ${IMAGE_FILE}"
        exit 4
    fi

    local size
    size=$(du -sh "${IMAGE_FILE}" | awk '{print $1}')

    if [[ "${yes}" == false ]]; then
        printf "usb-explore: Remove %s (%s)? [y/N] " \
            "${IMAGE_FILE}" "${size}" >&2
        local answer="n"
        read -r answer || answer="n"
        [[ "${answer}" =~ ^[Yy]$ ]] || { log "Aborted."; exit 0; }
    fi

    rm -f -- "${IMAGE_FILE}"
    log "Removed ${IMAGE_FILE} (${size})"
}

# ---------------------------------------------------------------------------
# Subcommand: copy
# ---------------------------------------------------------------------------

do_copy() {
    local src="" dest=""
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            -*) die "Unknown copy option: ${1}" ;;
            *)
                if [[ -z "${src}" ]]; then
                    src="${1}"
                elif [[ -z "${dest}" ]]; then
                    dest="${1}"
                else
                    die "Unexpected argument: ${1}"
                fi ;;
        esac
        shift
    done

    [[ -n "${src}" ]]  || die "copy requires <src-path>"
    [[ -n "${dest}" ]] || die "copy requires <dest>"
    [[ "${src}" == /* ]] || die "<src-path> must be absolute (start with /)"
    src="${src#/mnt/part}"

    check_docker
    check_image_file
    ensure_image
    resolve_partition
    set_tty_flags

    local out_dir out_name
    # Resolve host-side output directory; create if needed
    out_dir="$(cd "$(dirname "${dest}")" 2>/dev/null && pwd \
               || { mkdir -p "$(dirname "${dest}")" && \
                    cd "$(dirname "${dest}")" && pwd; })"
    out_name="$(basename "${dest}")"

    run_container \
        -v "${out_dir}:/out" \
        "${TTY_FLAGS[@]}" \
        "${IMAGE_REF}" copy "${src}" "${out_name}"
}

# ---------------------------------------------------------------------------
# Subcommand: diff
# ---------------------------------------------------------------------------

do_diff() {
    local img_path="" ref_path=""
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            -*) die "Unknown diff option: ${1}" ;;
            *)
                if [[ -z "${img_path}" ]]; then
                    img_path="${1}"
                elif [[ -z "${ref_path}" ]]; then
                    ref_path="${1}"
                else
                    die "Unexpected argument: ${1}"
                fi ;;
        esac
        shift
    done

    [[ -n "${img_path}" ]] || die "diff requires <image-path>"
    [[ -n "${ref_path}" ]] || die "diff requires <ref-path>"
    [[ "${img_path}" == /* ]] || die "<image-path> must be absolute (start with /)"
    img_path="${img_path#/mnt/part}"
    [[ -e "${ref_path}" ]] || die "Reference path not found: ${ref_path}"

    check_docker
    check_image_file
    ensure_image
    resolve_partition
    set_tty_flags

    local ref_dir ref_name
    ref_dir="$(cd "$(dirname "${ref_path}")" && pwd)"
    ref_name="$(basename "${ref_path}")"

    run_container \
        -v "${ref_dir}:/ref:ro" \
        "${TTY_FLAGS[@]}" \
        "${IMAGE_REF}" diff "${img_path}" "${ref_name}"
    # diff exit code propagates: 0=same, 1=different, 2=error
}

# ---------------------------------------------------------------------------
# Subcommand: edit
# ---------------------------------------------------------------------------

# do_edit — mount read-write with automatic APFS backup.
# Args:
#   [--yes]            skip confirmation prompt
#   [--] [cmd args...] run a command instead of an interactive shell
# Returns:
#   Exit code from the shell or command.
do_edit() {
    local yes=false
    while [[ $# -gt 0 && "${1}" != "--" ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            --yes|-y) yes=true ;;
            -*) die "Unknown edit option: ${1}" ;;
            *) break ;;
        esac
        shift
    done
    [[ "${1:-}" == "--" ]] && shift

    check_image_file

    # APFS reflink backup before any Docker operations
    local backup="${IMAGE_FILE}.pre-edit"
    if [[ ! -f "${backup}" ]]; then
        log "Creating backup: ${backup}"
        cp -c "${IMAGE_FILE}" "${backup}" 2>/dev/null \
            || cp "${IMAGE_FILE}" "${backup}"
    else
        log "Backup already exists: ${backup}"
    fi

    # Confirmation
    if [[ "${yes}" == false ]]; then
        printf "usb-explore: This will modify %s. Continue? [y/N] " \
            "${IMAGE_FILE}" >&2
        local answer="n"
        read -r answer || answer="n"
        [[ "${answer}" =~ ^[Yy]$ ]] || { log "Aborted."; exit 0; }
    fi

    check_docker
    ensure_image
    resolve_partition

    RW_MODE=true

    if [[ $# -gt 0 ]]; then
        # Rewrite leading-/ arguments to /mnt/part<path>
        local rewritten=()
        for arg in "$@"; do
            if [[ "${arg}" == /* ]]; then
                rewritten+=("/mnt/part${arg}")
            else
                rewritten+=("${arg}")
            fi
        done
        set_tty_flags
        local rc=0
        run_container \
            "${TTY_FLAGS[@]}" \
            "${IMAGE_REF}" run "${rewritten[@]}" || rc=$?
        return "${rc}"
    else
        local rc=0
        run_container \
            -i -t \
            "${IMAGE_REF}" shell || rc=$?
        if [[ "${rc}" -ne 130 && -t 2 ]]; then
            printf '\033[1A\033[2K\r' >&2
        fi
        [[ "${rc}" -eq 130 ]] && return 0
        return "${rc}"
    fi
}

# ---------------------------------------------------------------------------
# Subcommand: find
# ---------------------------------------------------------------------------

# Search the partition by filename glob, file contents, or both.
# Args:
#   [-p|--partition N]  override auto-detected partition number
#   [NAME-GLOB]         glob matched against file basenames (e.g. "*.log")
#   [--grep PATTERN]    regex/string searched in file contents
# Returns:
#   0 on success; 1 when --grep finds no matches (grep standard exit)
do_find() {
    local name_pattern="" grep_pattern=""
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            --grep)
                [[ -n "${2:-}" ]] || die "--grep requires a pattern"
                grep_pattern="${2}"; shift ;;
            -*) die "Unknown find option: ${1}" ;;
            *)
                [[ -z "${name_pattern}" ]] \
                    || die "Unexpected argument: ${1}"
                name_pattern="${1}" ;;
        esac
        shift
    done

    [[ -n "${name_pattern}" || -n "${grep_pattern}" ]] \
        || die "find requires a NAME-GLOB and/or --grep PATTERN"

    check_docker
    check_image_file
    ensure_image
    resolve_partition

    local find_args=()
    [[ -n "${name_pattern}" ]] && find_args+=("${name_pattern}")
    [[ -n "${grep_pattern}" ]] && find_args+=("--grep" "${grep_pattern}")

    run_container \
        "${IMAGE_REF}" find "${find_args[@]}"
}

# ---------------------------------------------------------------------------
# Subcommand: hash
# ---------------------------------------------------------------------------

# Print the SHA-256 checksum of a file from the partition without extraction.
# Args:
#   [-p|--partition N]  override auto-detected partition number
#   <path>              absolute path within the partition
# Returns:
#   0 on success; 1 if path not found or is a directory
do_hash() {
    local src=""
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            -*) die "Unknown hash option: ${1}" ;;
            *)
                [[ -z "${src}" ]] || die "Unexpected argument: ${1}"
                src="${1}" ;;
        esac
        shift
    done

    [[ -n "${src}" ]] || die "hash requires a <path> argument"
    [[ "${src}" == /* ]] || die "<path> must be absolute (start with /)"
    src="${src#/mnt/part}"

    check_docker
    check_image_file
    ensure_image
    resolve_partition

    run_container \
        "${IMAGE_REF}" hash "${src}"
}

# ---------------------------------------------------------------------------
# Subcommand: info
# ---------------------------------------------------------------------------

do_info() {
    local json_mode=""
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            --json) json_mode="--json" ;;
            *) die "Unknown info option: ${1}" ;;
        esac
        shift
    done

    check_docker
    check_image_file
    ensure_image
    set_tty_flags

    run_container \
        "${TTY_FLAGS[@]}" \
        "${IMAGE_REF}" info ${json_mode}
}

# ---------------------------------------------------------------------------
# Subcommand: run
# ---------------------------------------------------------------------------

do_run() {
    # Accept -p/--partition and --rw here so 'usb-explore run --rw -- cmd' works.
    # -- ends option parsing; anything after it is the command to exec.
    while [[ $# -gt 0 && "${1}" != "--" ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            --rw) RW_MODE=true ;;
            -*) die "Unknown run option: ${1}
       Pass -p before the subcommand:  usb-explore -p N run -- <cmd>
       or between subcommand and --:   usb-explore run -p N -- <cmd>" ;;
            *) break ;;
        esac
        shift
    done
    [[ "${1:-}" == "--" ]] && shift

    [[ $# -gt 0 ]] || die "run requires a command after [--]"

    check_docker
    check_image_file
    ensure_image
    resolve_partition
    set_tty_flags

    # Rewrite leading-/ arguments to /mnt/part<path>
    local rewritten=()
    for arg in "$@"; do
        if [[ "${arg}" == /* ]]; then
            rewritten+=("/mnt/part${arg}")
        else
            rewritten+=("${arg}")
        fi
    done

    run_container \
        "${TTY_FLAGS[@]}" \
        "${IMAGE_REF}" run "${rewritten[@]}"
}

# ---------------------------------------------------------------------------
# Subcommand: mount
# ---------------------------------------------------------------------------

# do_mount — mount the partition as a Finder-browseable SMB volume.
# Args:
#   [--port PORT]    SMB port (default: 44500)
#   [--no-open]      suppress automatic Finder open
# Returns:
#   Runs until interrupted; exit code reflects container exit code.
do_mount() {
    local port=44500
    local no_open=false
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            --port)
                [[ -n "${2:-}" ]] || die "--port requires a number"
                port="${2}"; shift ;;
            --no-open) no_open=true ;;
            -*) die "Unknown mount option: ${1}" ;;
        esac
        shift
    done

    if ! [[ "${port}" =~ ^[0-9]+$ ]] || (( port < 1 || port > 65535 )); then
        die "--port must be a number between 1 and 65535"
    fi

    if lsof -i ":${port}" >/dev/null 2>&1; then
        die "Port ${port} is already in use." \
            "Pass --port to specify a different port."
    fi

    check_docker
    check_image_file
    ensure_image
    resolve_partition

    local share_name="usb-explore-$$"

    if [[ -n "${SSH_CONNECTION:-}" || -n "${SSH_TTY:-}" ]]; then
        no_open=true
    fi

    log "Mounting partition ${PARTITION} via SMB"
    log "  Share: smb://guest@localhost:${port}/${share_name}"
    log "  Volume: /Volumes/${share_name}"
    log "Press Ctrl-C to unmount and stop."

    if [[ "${no_open}" == false ]] && command -v open >/dev/null 2>&1; then
        ( sleep 2 && open "smb://guest@localhost:${port}/${share_name}" ) &
    fi

    local rc=0
    run_container \
        -p "${port}:${port}" \
        "${IMAGE_REF}" mount-server "${port}" "${share_name}" || rc=$?
    [[ "${rc}" -eq 130 ]] && return 0
    return "${rc}"
}

# ---------------------------------------------------------------------------
# Subcommand: unmount
# ---------------------------------------------------------------------------

# do_unmount — unmount all usb-explore SMB volumes.
# Args: none
# Returns: 0
do_unmount() {
    local found=false
    for vol in /Volumes/usb-explore-*; do
        if [[ -d "${vol}" ]]; then
            diskutil unmount "${vol}" 2>/dev/null || \
                umount "${vol}" 2>/dev/null || true
            found=true
            log "Unmounted ${vol}"
        fi
    done

    if [[ "${found}" == false ]]; then
        log "No usb-explore mounts found"
    fi
}

# ---------------------------------------------------------------------------
# Subcommand: serve
# ---------------------------------------------------------------------------

# do_serve — start a read-only HTTP directory server over the mounted partition.
# Args:
#   [--port PORT]    host port to listen on (default: 8080)
#   [--no-open]      suppress automatic browser launch
# Returns:
#   Runs until interrupted; exit code reflects container exit code.
do_serve() {
    local port=8080
    local no_open=false
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            --port)
                [[ -n "${2:-}" ]] || die "--port requires a number"
                port="${2}"; shift ;;
            --no-open) no_open=true ;;
            -*) die "Unknown serve option: ${1}" ;;
        esac
        shift
    done

    if ! [[ "${port}" =~ ^[0-9]+$ ]] || (( port < 1 || port > 65535 )); then
        die "--port must be a number between 1 and 65535"
    fi

    check_docker
    check_image_file
    ensure_image
    resolve_partition

    log "Serving partition ${PARTITION} at http://localhost:${port}/"
    log "Press Ctrl-C to stop."

    # Auto-suppress browser launch in SSH sessions and headless environments.
    if [[ -n "${SSH_CONNECTION:-}" || -n "${SSH_TTY:-}" ]]; then
        no_open=true
    fi

    if [[ "${no_open}" == false ]] && command -v open >/dev/null 2>&1; then
        ( sleep 1 && open "http://localhost:${port}/" ) &
    fi

    local rc=0
    run_container \
        -p "${port}:8080" \
        "${IMAGE_REF}" serve || rc=$?
    [[ "${rc}" -eq 130 ]] && return 0
    return "${rc}"
}

# ---------------------------------------------------------------------------
# Subcommand: shell
# ---------------------------------------------------------------------------

do_shell() {
    while [[ $# -gt 0 ]]; do
        case "${1}" in
            -p|--partition)
                [[ -n "${2:-}" ]] || die "--partition requires a number"
                PARTITION="${2}"; shift ;;
            --rw) RW_MODE=true ;;
            -*) die "Unknown shell option: ${1}" ;;
            *)  die "Unexpected argument: ${1}" ;;
        esac
        shift
    done

    check_docker
    check_image_file
    ensure_image
    resolve_partition

    local rc=0
    run_container \
        -i -t \
        "${IMAGE_REF}" shell || rc=$?
    # When an interactive bash session ends (user typed "exit" or pressed
    # Ctrl-D), bash itself prints "exit" to the terminal.  When the user
    # typed "exit", the PTY already echoed the keystrokes, so bash's own
    # print produces a spurious second "exit" line after the session ends.
    # Erasing one line (cursor-up + clear-line) after the container exits
    # removes that trailing artefact.  Only applied when stderr is a real
    # terminal and the session ended normally (not Ctrl-C, rc=130).
    if [[ "${rc}" -ne 130 && -t 2 ]]; then
        printf '\033[1A\033[2K\r' >&2
    fi
    [[ "${rc}" -eq 130 ]] && return 0
    return "${rc}"
}

# ---------------------------------------------------------------------------
# Argument parsing (global options + subcommand dispatch)
# ---------------------------------------------------------------------------

usage() {
    awk '/^# SYNOPSIS/{f=1;next} /^# EXAMPLES/{exit} f && !/^#$/{sub(/^# ?/,""); print}' \
        "${BASH_SOURCE[0]}"
}

print_version() {
    local ver="(unknown)"
    if [[ -f "${REPO_ROOT}/version.txt" ]]; then
        ver="$(cat "${REPO_ROOT}/version.txt")"
    fi
    echo "usb-explore ${ver}  image=${IMAGE_REF}"
}

# When sourced (e.g. by tests), skip argument parsing so only the
# function definitions are loaded.
[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return 0

SUBCOMMAND=""

while [[ $# -gt 0 ]]; do
    case "${1}" in
        -i|--image)
            [[ -n "${2:-}" ]] || die "--image requires a path"
            IMAGE_FILE="${2}"; shift ;;
        -p|--partition)
            [[ -n "${2:-}" ]] || die "--partition requires a number"
            PARTITION="${2}"; shift ;;
        --lv)
            [[ -n "${2:-}" ]] || die "--lv requires a logical volume name"
            LV_NAME="${2}"; shift ;;
        --luks-passphrase)
            [[ -n "${2:-}" ]] || die "--luks-passphrase requires a value"
            LUKS_PASSPHRASE="${2}"; shift ;;
        --luks-passphrase-file)
            [[ -n "${2:-}" ]] || die "--luks-passphrase-file requires a path"
            LUKS_PASSPHRASE_FILE="${2}"; shift ;;
        --luks-key-file)
            [[ -n "${2:-}" ]] || die "--luks-key-file requires a path"
            LUKS_KEY_FILE="${2}"; shift ;;
        --debug)     DEBUG=true ;;
        --version)   print_version; exit 0 ;;
        --help|-h)   usage; exit 0 ;;
        archive|browse|build|capture|clean|copy|diff|edit|find|hash|info|mount|run|serve|shell|unmount)
            SUBCOMMAND="${1}"; shift; break ;;
        -*)
            die "Unknown option: ${1}. Run 'usb-explore --help' for usage." ;;
        *)
            die "Unknown subcommand: ${1}. Run 'usb-explore --help' for usage." ;;
    esac
    shift
done

[[ -n "${SUBCOMMAND}" ]] || { usage; exit 2; }

case "${SUBCOMMAND}" in
    archive) do_archive "$@" ;;
    browse)  do_browse  "$@" ;;
    build)   do_build   "$@" ;;
    capture) do_capture "$@" ;;
    clean)   do_clean   "$@" ;;
    copy)    do_copy    "$@" ;;
    diff)    do_diff    "$@" ;;
    edit)    do_edit    "$@" ;;
    find)    do_find    "$@" ;;
    hash)    do_hash    "$@" ;;
    info)    do_info    "$@" ;;
    mount)   do_mount   "$@" ;;
    run)     do_run     "$@" ;;
    serve)   do_serve   "$@" ;;
    shell)   do_shell   "$@" ;;
    unmount) do_unmount "$@" ;;
esac
