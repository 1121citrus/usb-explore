#!/usr/bin/env bash
# Local CI equivalent for usb-explore.
# Mirrors the GitHub Actions pipeline exactly.
# Usage: ./build [options]  (run with --help for full option list)
set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults (all overridable via env vars or CLI flags)
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

VERSION="${BUILD_VERSION:-}"
PUSH="${BUILD_PUSH:-false}"
PLATFORM="${BUILD_PLATFORM:-}"
REGISTRY="${BUILD_REGISTRY:-1121citrus}"
IMAGE="${REGISTRY}/usb-explore"

DO_LINT="${BUILD_LINT:-true}"
DO_TEST="${BUILD_TEST:-true}"
DO_SCAN="${BUILD_SCAN:-true}"
DO_SCAN_GRYPE="${BUILD_SCAN_GRYPE:-true}"
DO_SCAN_SCOUT="${BUILD_SCAN_SCOUT:-true}"
DO_STAGING=false
DO_SBOM=true
DO_PROVENANCE=true
DRY_RUN=false
ADVISE=""

TRIVY_CACHE_VOL="${IMAGE##*/}-trivy-cache"
GRYPE_CACHE_VOL="${IMAGE##*/}-grype-cache"

CACHE_RESET=""
CACHE_SKIP_UPDATE=""

# ---------------------------------------------------------------------------
# Colours
# ---------------------------------------------------------------------------

if [[ -t 1 ]]; then
    RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m'
    CYAN='\033[0;36m' BOLD='\033[1m' RESET='\033[0m'
else
    RED='' GREEN='' YELLOW='' CYAN='' BOLD='' RESET=''
fi

log()   { echo -e "${CYAN}==>${RESET} ${BOLD}${*}${RESET}"; }
ok()    { echo -e "${GREEN}  ✓${RESET} ${*}"; }
warn()  { echo -e "${YELLOW}  !${RESET} ${*}"; }
err()   { echo -e "${RED}  ✗${RESET} ${*}" >&2; }
die()   { err "${*}"; exit 1; }

# ---------------------------------------------------------------------------
# run() — execute or print (dry-run)
# ---------------------------------------------------------------------------

run() {
    if [[ "${DRY_RUN}" == true ]]; then
        echo "[dry-run] $*"
    else
        "$@"
    fi
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

usage() {
    cat <<'EOF'
Usage: ./build [options]

Stages (all on by default unless skipped):
  1  lint        hadolint, shellcheck, markdownlint
  2  build       docker buildx build --load
  3  test        bats test suite
  4  scan        trivy, grype, docker scout
  5  push        multi-platform push to registry (opt-in)

Options:
  --push                  Push to registry after build
  --version VERSION       Set image version tag (default: dev-<sha>)
  --platform PLATFORMS    Comma-separated buildx platforms
  --registry REGISTRY     Registry prefix (default: 1121citrus)
  --no-sbom               Disable SBOM generation on push
  --no-provenance         Disable provenance attestation on push
  --no-lint               Skip lint stage
  --no-test               Skip test stage
  --run-staging           Run staging tests (if test/staging exists)
  --no-scan               Skip all scan stages
  --advise ADVISEMENTS    Comma-separated: dive,coverage,metrics,all,none
  --cache SPEC            reset=trivy|grype|all  skip-update=trivy|grype|all
  --dry-run               Print commands without executing
  --help                  Show this help
EOF
}

while [[ $# -gt 0 ]]; do
    case "${1}" in
        --push)            PUSH=true ;;
        --version)         VERSION="${2}"; shift ;;
        --platform)        PLATFORM="${2}"; shift ;;
        --registry)        REGISTRY="${2}"; IMAGE="${REGISTRY}/usb-explore" ;;
        --no-sbom)         DO_SBOM=false ;;
        --no-provenance)   DO_PROVENANCE=false ;;
        --no-lint)         DO_LINT=false ;;
        --no-test)         DO_TEST=false ;;
        --run-staging)     DO_STAGING=true ;;
        --no-scan)         DO_SCAN=false; DO_SCAN_GRYPE=false
                           DO_SCAN_SCOUT=false ;;
        --advise)          ADVISE="${2}"; shift ;;
        --cache)           # e.g. --cache "reset=trivy;skip-update=grype"
            for _spec in ${2//;/ }; do
                _k="${_spec%%=*}"; _v="${_spec#*=}"
                case "${_k}" in
                    reset)       CACHE_RESET="${_v}" ;;
                    skip-update) CACHE_SKIP_UPDATE="${_v}" ;;
                    *) die "Unknown cache key: ${_k}" ;;
                esac
            done
            shift ;;
        --dry-run)         DRY_RUN=true ;;
        --help|-h)         usage; exit 0 ;;
        *) die "Unknown option: ${1}. Run ./build --help for usage." ;;
    esac
    shift
done

# ---------------------------------------------------------------------------
# Version derivation
# ---------------------------------------------------------------------------

if [[ -z "${VERSION}" ]]; then
    _sha=$(git -C "${SCRIPT_DIR}" rev-parse --short HEAD 2>/dev/null \
           || echo "unknown")
    VERSION="dev-${_sha}"
fi

GIT_COMMIT=$(git -C "${SCRIPT_DIR}" rev-parse HEAD 2>/dev/null \
             || echo "unknown")
BUILD_DATE=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# ---------------------------------------------------------------------------
# Platform
# ---------------------------------------------------------------------------

if [[ -z "${PLATFORM}" ]]; then
    PLATFORM=$(docker info --format '{{.OSType}}/{{.Architecture}}' \
               2>/dev/null || echo "linux/amd64")
fi

# ---------------------------------------------------------------------------
# Tags
# ---------------------------------------------------------------------------

TAGS=("--tag" "${IMAGE}:${VERSION}")
if [[ "${VERSION}" == dev-* ]]; then
    TAGS+=("--tag" "${IMAGE}:dev-latest")
else
    if [[ "${PUSH}" != true ]]; then
        TAGS+=("--tag" "${IMAGE}:latest")
    fi
fi

PUSH_TAGS=("--tag" "${IMAGE}:${VERSION}")
if [[ "${VERSION}" != dev-* ]]; then
    PUSH_TAGS+=("--tag" "${IMAGE}:latest")
else
    PUSH_TAGS+=("--tag" "${IMAGE}:dev-latest")
fi

# ---------------------------------------------------------------------------
# Cache helpers
# ---------------------------------------------------------------------------

_cache_applies() {
    local target="${1}" spec="${2}"
    [[ "${spec}" == "all" || "${spec}" == "${target}" ]]
}

reset_cache_vol() {
    local vol="${1}"
    log "Resetting cache volume: ${vol}"
    run docker volume rm "${vol}" 2>/dev/null || true
    run docker volume create "${vol}"
}

# ---------------------------------------------------------------------------
# Stage 1: Lint
# ---------------------------------------------------------------------------

stage_lint() {
    log "Stage 1: Lint"

    log "  hadolint"
    run docker run --rm \
        -v "${SCRIPT_DIR}/Dockerfile:/Dockerfile:ro" \
        hadolint/hadolint:latest hadolint /Dockerfile \
        && ok "hadolint passed"

    log "  shellcheck"
    run docker run --rm \
        -v "${SCRIPT_DIR}:/src:ro" \
        -w /src \
        koalaman/shellcheck:stable \
        shellcheck -S warning -x \
            src/usb-explore \
            src/container/entrypoint.sh \
            src/container/info.sh \
            src/container/dispatch.sh \
            src/container/drivers/ext.sh \
            src/container/drivers/xfs.sh \
            src/container/drivers/vfat.sh \
        && ok "shellcheck passed"

    log "  markdownlint"
    run docker run --rm \
        -v "${SCRIPT_DIR}:/src:ro" \
        -w /src \
        davidanson/markdownlint-cli2:latest \
        "**/*.md" \
        && ok "markdownlint passed"
}

# ---------------------------------------------------------------------------
# Stage 2: Build
# ---------------------------------------------------------------------------

stage_build() {
    log "Stage 2: Build  [${PLATFORM}]  version=${VERSION}"
    run docker buildx build \
        --platform "${PLATFORM}" \
        --build-arg "VERSION=${VERSION}" \
        --build-arg "GIT_COMMIT=${GIT_COMMIT}" \
        --build-arg "BUILD_DATE=${BUILD_DATE}" \
        "${TAGS[@]}" \
        --load \
        "${SCRIPT_DIR}"
    ok "Image built: ${IMAGE}:${VERSION}"
}

# ---------------------------------------------------------------------------
# Stage 3: Test
# ---------------------------------------------------------------------------

stage_test() {
    log "Stage 3: Test"

    # Generate fixture images if missing
    if [[ ! -f "${SCRIPT_DIR}/fixtures/single-ext4.img" ]]; then
        log "  Generating test fixtures..."
        run bash "${SCRIPT_DIR}/fixtures/generate.sh"
    fi

    if [[ -x "${SCRIPT_DIR}/test/run-all" ]]; then
        run IMAGE="${IMAGE}:${VERSION}" \
            bash "${SCRIPT_DIR}/test/run-all"
    else
        run docker run --rm \
            -v "${SCRIPT_DIR}:${SCRIPT_DIR}" \
            -v /var/run/docker.sock:/var/run/docker.sock \
            -w "${SCRIPT_DIR}" \
            -e "IMAGE=${IMAGE}:${VERSION}" \
            bats/bats:1.13.0 \
            bats \
                test/01-build.bats \
                test/02-image-structure.bats \
                test/03-invocation.bats \
                test/04-env-metadata.bats \
                test/05-partition-discovery.bats \
                test/06-subcommands.bats
    fi
    ok "Tests passed"
}

# ---------------------------------------------------------------------------
# Stage 3b: Staging (opt-in)
# ---------------------------------------------------------------------------

stage_staging() {
    if [[ -x "${SCRIPT_DIR}/test/staging" ]]; then
        log "Stage 3b: Staging"
        run IMAGE="${IMAGE}:${VERSION}" bash "${SCRIPT_DIR}/test/staging"
        ok "Staging passed"
    else
        warn "No test/staging script found; skipping."
    fi
}

# ---------------------------------------------------------------------------
# Stage 4: Scan
# ---------------------------------------------------------------------------

stage_scan_trivy() {
    log "Stage 4a: Scan (Trivy)"

    if _cache_applies trivy "${CACHE_RESET}"; then
        reset_cache_vol "${TRIVY_CACHE_VOL}"
    fi

    local skip_update=""
    if _cache_applies trivy "${CACHE_SKIP_UPDATE}"; then
        skip_update="--skip-update"
    fi

    run docker run --rm \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v "${TRIVY_CACHE_VOL}:/root/.cache/trivy" \
        aquasec/trivy:latest image \
        --ignore-unfixed \
        --severity HIGH,CRITICAL \
        --timeout 5m \
        ${skip_update} \
        "${IMAGE}:${VERSION}"
    ok "Trivy passed"
}

stage_scan_grype() {
    log "Stage 4b: Scan (Grype)"

    if _cache_applies grype "${CACHE_RESET}"; then
        reset_cache_vol "${GRYPE_CACHE_VOL}"
    fi

    local update_flag="--update-db"
    if _cache_applies grype "${CACHE_SKIP_UPDATE}"; then
        update_flag="--skip-update"
    fi

    local grype_config_args=()
    if [[ -f "${SCRIPT_DIR}/.grype.yaml" ]]; then
        grype_config_args=(--config /config/.grype.yaml)
    fi

    run docker run --rm \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v "${GRYPE_CACHE_VOL}:/root/.cache/grype" \
        -v "${SCRIPT_DIR}:/config:ro" \
        anchore/grype:latest \
        "${update_flag}" \
        "${grype_config_args[@]}" \
        "${IMAGE}:${VERSION}"
    ok "Grype passed"
}

stage_scan_scout() {
    log "Stage 4c: Scan (Docker Scout)"
    if ! docker scout version >/dev/null 2>&1; then
        warn "docker scout not available; skipping."
        return 0
    fi
    run docker scout cves "${IMAGE}:${VERSION}"
    ok "Scout passed"
}

# ---------------------------------------------------------------------------
# Stage 5: Advise
# ---------------------------------------------------------------------------

_advise_applies() {
    local name="${1}"
    [[ "${ADVISE}" == "all" \
    || "${ADVISE}" == "${name}" \
    || "${ADVISE}" == *",${name}"* \
    || "${ADVISE}" == *"${name},"* ]]
}

stage_advise() {
    if _advise_applies dive; then
        log "Advise: Dive (layer analysis)"
        run docker run --rm \
            -v /var/run/docker.sock:/var/run/docker.sock \
            wagoodman/dive:latest "${IMAGE}:${VERSION}" || true
    fi

    if _advise_applies metrics; then
        log "Advise: Metrics (scc)"
        run docker run --rm \
            -v "${SCRIPT_DIR}:/src:ro" \
            -w /src \
            boyter/scc:latest scc src/ || true
    fi
}

# ---------------------------------------------------------------------------
# Stage 6: Push
# ---------------------------------------------------------------------------

stage_push() {
    log "Stage 6: Push  [linux/amd64,linux/arm64]  version=${VERSION}"

    local sbom_flag="" prov_flag=""
    [[ "${DO_SBOM}" == true ]]       && sbom_flag="--sbom=true"
    [[ "${DO_PROVENANCE}" == true ]] && prov_flag="--provenance=mode=max"

    run docker buildx build \
        --platform linux/amd64,linux/arm64 \
        --build-arg "VERSION=${VERSION}" \
        --build-arg "GIT_COMMIT=${GIT_COMMIT}" \
        --build-arg "BUILD_DATE=${BUILD_DATE}" \
        "${PUSH_TAGS[@]}" \
        ${sbom_flag} \
        ${prov_flag} \
        --push \
        "${SCRIPT_DIR}"
    ok "Pushed: ${PUSH_TAGS[*]}"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

echo ""
echo -e "${BOLD}usb-explore build${RESET}  version=${VERSION}  push=${PUSH}"
echo ""

[[ "${DO_LINT}" == true ]]        && stage_lint
stage_build
[[ "${DO_TEST}" == true ]]        && stage_test
[[ "${DO_STAGING}" == true ]]     && stage_staging
[[ "${DO_SCAN}" == true ]]        && stage_scan_trivy
[[ "${DO_SCAN_GRYPE}" == true ]]  && stage_scan_grype
[[ "${DO_SCAN_SCOUT}" == true ]]  && stage_scan_scout
[[ -n "${ADVISE}" && "${ADVISE}" != "none" ]] && stage_advise
[[ "${PUSH}" == true ]]           && stage_push

echo ""
ok "Build complete: ${IMAGE}:${VERSION}"
echo ""
